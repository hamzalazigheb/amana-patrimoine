generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  keywords    String?
  coverImage  String?  @map("cover_image")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  blocks      Block[]
}

model Block {
  id        String   @id @default(cuid())
  pageId    String   @map("page_id")
  type      String
  order     Int      @default(0)
  content   String   @default("{}")  // kept as String for compatibility with existing code
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([pageId, order])
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String
  mimeType  String?  @map("mime_type")
  size      Int?
  alt       String?
  createdAt DateTime @default(now()) @map("created_at")
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  ip        String?
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
}

model WhitePaperDownload {
  id            String   @id @default(cuid())
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String
  phone         String
  project       String?
  paperIds      String   @map("paper_ids")
  newsletter    Boolean  @default(false)
  downloadToken String   @unique @map("download_token") @default(cuid())
  expiresAt     DateTime @map("expires_at")
  ip            String?
  status        String   @default("new")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("whitepaper_downloads")
}
