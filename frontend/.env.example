# ─── Database ────────────────────────────────────────────────────────────────
# Provider: "postgresql" for production, "sqlite" for local dev
DATABASE_PROVIDER=postgresql
# PostgreSQL connection string
# Local example :  postgresql://postgres:password@localhost:5432/amana_patrimoine
# Supabase       :  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/amana_patrimoine"

# ─── Authentication secrets ───────────────────────────────────────────────────
# Generate strong values with:  node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET="REPLACE_WITH_64_RANDOM_CHARS"
NEXTAUTH_SECRET="REPLACE_WITH_64_RANDOM_CHARS"
NEXTAUTH_URL="https://amana-patrimoine.fr"

# ─── Security ─────────────────────────────────────────────────────────────────
# Set to true ONLY after SSL/HTTPS is configured on the server (enables Secure cookie flag + HSTS header)
HTTPS_ENABLED=false
ENABLE_HSTS=false

# ─── Admin ────────────────────────────────────────────────────────────────────
# Password for the /admin panel. Change immediately after first deploy.
ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# ─── SEO / Canonical URL ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://amana-patrimoine.fr

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Chatbot ──────────────────────────────────────────────────────────────────
# After SSL: chatbot is proxied through Nginx at /chatbot/ — no mixed-content issues.
# The default below works out of the box once SSL + Nginx proxy are configured.
NEXT_PUBLIC_CHATBOT_ENABLED=false
NEXT_PUBLIC_CHATBOT_ID=69cefcc8cdd78aded2e4c7be
NEXT_PUBLIC_CHATBOT_API_URL=https://amana-patrimoine.fr/chatbot

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=33189700000

# ─── Landing platform (/platform) ───────────────────────────────────────────
# URL for "Démarrer mon parcours" CTA buttons
NEXT_PUBLIC_LANDING_PARCOURS_URL=https://platform.amana-patrimoine.fr/onboard
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/amana-patrimoine/30min
NEXT_PUBLIC_LANDING_LOGIN_URL=/admin/login
NEXT_PUBLIC_CONTACT_EMAIL=contact@amana-patrimoine.fr
NEXT_PUBLIC_PLATFORM_AUTH_URL=https://platform.amana-patrimoine.fr/auth
