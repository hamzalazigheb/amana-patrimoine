# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local example :  postgresql://postgres:password@localhost:5432/amana_patrimoine
# Supabase       :  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/amana_patrimoine"

# ─── Authentication secrets ───────────────────────────────────────────────────
# Generate strong values with:  node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET="REPLACE_WITH_64_RANDOM_CHARS"
NEXTAUTH_SECRET="REPLACE_WITH_64_RANDOM_CHARS"
NEXTAUTH_URL="https://amana-patrimoine.fr"

# ─── Security ─────────────────────────────────────────────────────────────────
# Set to true ONLY after SSL/HTTPS is configured on the server (enables Secure cookie flag)
HTTPS_ENABLED=false

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── SEO ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://amana-patrimoine.fr
