# ══════════════════════════════════════════════════════
# Amana Patrimoine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════

# ── Database (PostgreSQL) ──────────────────────────
# Local dev (with docker-compose.dev.yml):
# DATABASE_URL="postgresql://amana:amana_dev_local@localhost:5432/amana_patrimoine"
#
# Production (on AWS, DB is on internal Docker network):
# DATABASE_URL="postgresql://amana:YOUR_PASSWORD@db:5432/amana_patrimoine"
#
# External cloud DB (e.g. Supabase / RDS):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_URL="postgresql://amana:amana_dev_local@localhost:5432/amana_patrimoine"

# ── JWT Secret ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-hex"

# ── Admin account ──────────────────────────────────
# Used by prisma/seed.js to create the first admin user
ADMIN_PASSWORD="choose-a-strong-password"

# ── App URL ────────────────────────────────────────
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"

# ══════════════════════════════════════════════════════
# Production-only variables (set on AWS server)
# ══════════════════════════════════════════════════════

# PostgreSQL credentials (used by docker-compose.yml)
# POSTGRES_DB=amana_patrimoine
# POSTGRES_USER=amana
# POSTGRES_PASSWORD=choose-a-very-strong-password
